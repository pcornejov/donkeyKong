---
// Presentational card for a game entry. Consumed by src/pages/juegos/index.astro
// (owned by the "coder" agent), which maps entries from the `games` content
// collection onto these props.
//
// NOTE on `platforms`: the games content collection schema
// (src/content/config.ts) defines `platforms: string[]` (a game can have
// shipped on several systems), so this card's final, single source of truth
// for platform info is the `platforms` array — there is no singular
// `platform` prop anymore. Always pass an array, even for a one-platform
// game (e.g. `platforms={['Arcade']}`).
interface Props {
  title: string;
  year: string | number;
  platforms: string[];
  description: string;
  href: string;
}

const { title, year, platforms, description, href } = Astro.props;
---

<a class="game-card surface" href={href}>
  <div class="game-card__media" aria-hidden="true">
    <span class="game-card__glyph">👾</span>
  </div>

  <div class="game-card__body">
    <div class="game-card__meta">
      <span class="game-card__year">{year}</span>
      <ul class="chip-list game-card__platforms">
        {platforms.map((platform) => (
          <li class="chip">{platform}</li>
        ))}
      </ul>
    </div>

    <h3 class="game-card__title">{title}</h3>
    <p class="game-card__description">{description}</p>

    <span class="game-card__cta">Ver ficha →</span>
  </div>
</a>

<style>
  .game-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    text-decoration: none;
    color: var(--color-text);
    box-shadow: var(--shadow-card);
    transition: transform var(--transition-base), box-shadow var(--transition-base),
      border-color var(--transition-base);
    height: 100%;
  }

  .game-card:hover,
  .game-card:focus-visible {
    color: var(--color-text);
    transform: translateY(-4px);
    box-shadow: var(--shadow-card-hover);
    border-color: var(--color-primary);
  }

  .game-card__media {
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 16 / 9;
    background: linear-gradient(135deg, var(--color-surface-alt), var(--color-bg-elevated));
    border-bottom: var(--border-width) solid var(--color-border);
  }

  .game-card__glyph {
    font-size: 2.5rem;
    filter: drop-shadow(0 0 10px var(--color-primary-glow));
  }

  .game-card__body {
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    flex: 1;
  }

  .game-card__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .game-card__year {
    font-family: var(--font-heading);
    font-size: 0.625rem;
    /* --color-link: contrast-safe variant of the same cyan hue as
       --color-secondary — see tokens.css. */
    color: var(--color-link);
    text-transform: uppercase;
    flex: none;
  }

  .game-card__platforms {
    /* Chips take over from what used to be a single "• PLATFORM" string;
       row-gap lets them wrap onto a second line without crowding. */
    row-gap: var(--space-1);
  }

  .game-card__title {
    font-size: var(--font-size-base);
    margin-block: var(--space-1);
  }

  .game-card__description {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    flex: 1;
  }

  .game-card__cta {
    margin-top: var(--space-2);
    font-family: var(--font-heading);
    font-size: var(--font-size-xs);
    /* --color-primary-text: contrast-safe variant of the same amber hue as
       --color-primary — see tokens.css. */
    color: var(--color-primary-text);
  }
</style>
