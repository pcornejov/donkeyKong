---
// Site navigation. Uses import.meta.env.BASE_URL so links keep working
// under the configured base path (e.g. GitHub Pages project sites).
const base = import.meta.env.BASE_URL;

const links = [
  { label: 'Inicio', href: `${base}` },
  { label: 'Juegos', href: `${base}juegos/` },
  { label: 'Personajes', href: `${base}personajes/` },
  { label: 'Lore', href: `${base}lore/` },
];
---

<header class="site-nav">
  <div class="container site-nav__inner">
    <a class="site-nav__brand" href={base}>
      <span class="site-nav__brand-mark" aria-hidden="true">★</span>
      <span>DK Encyclopedia</span>
    </a>

    <nav aria-label="Navegación principal">
      <ul class="site-nav__links">
        {
          links.map((link) => (
            <li>
              <a class="site-nav__link" href={link.href}>
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background-color: var(--color-bg-elevated);
    border-bottom: var(--border-width) solid var(--color-border);
    min-height: var(--nav-height);
  }

  .site-nav__inner {
    min-height: var(--nav-height);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
    padding-block: var(--space-3);
  }

  .site-nav__brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-heading);
    font-size: var(--font-size-sm);
    color: var(--color-text);
    text-decoration: none;
  }

  .site-nav__brand:hover,
  .site-nav__brand:focus-visible {
    color: var(--color-primary);
  }

  .site-nav__brand-mark {
    color: var(--color-primary);
  }

  .site-nav__links {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .site-nav__link {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: var(--font-size-xs);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast), background-color var(--transition-fast);
  }

  .site-nav__link:hover,
  .site-nav__link:focus-visible {
    color: var(--color-bg);
    background-color: var(--color-secondary);
  }
</style>
