---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GameDetailHeader from '../../components/GameDetailHeader.astro';
import { findMentions } from '../../utils/related';

export async function getStaticPaths() {
  const games = await getCollection('games');
  return games.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'games'>;
}

const { entry } = Astro.props;
const { title, releaseYear, platforms, developer, publisher, tags, description } = entry.data;
const { Content } = await entry.render();

const base = import.meta.env.BASE_URL;

// "Relacionados": personajes y entradas de lore mencionados por nombre en
// la descripción de este juego (ver src/utils/related.ts).
const [characters, loreEntries] = await Promise.all([getCollection('characters'), getCollection('lore')]);

const related = findMentions(description, [
  ...characters.map((c) => ({
    label: c.data.name,
    type: 'Personaje',
    href: `${base}personajes/${c.slug}/`,
  })),
  ...loreEntries.map((l) => ({
    label: l.data.title,
    type: 'Lore',
    href: `${base}lore/${l.slug}/`,
  })),
]);
---

<BaseLayout title={`${title} - Enciclopedia de Donkey Kong`} description={description}>
  <article>
    <GameDetailHeader
      title={title}
      releaseYear={releaseYear}
      platforms={platforms}
      developer={developer}
      publisher={publisher}
      tags={tags}
    />

    <div class="game-detail-body">
      <Content />
    </div>

    {related.length > 0 && (
      <section class="related">
        <h2>Relacionados</h2>
        <ul class="chip-list related__list" role="list">
          {related.map((item) => (
            <li>
              <a class="chip related__chip" href={item.href}>
                <span class="related__type">{item.type}:</span> {item.label}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </article>
</BaseLayout>

<style>
  .game-detail-body {
    padding-block: var(--space-6);
    max-width: 70ch;
  }

  .game-detail-body :global(p) {
    margin-block-end: var(--space-4);
  }

  .related {
    max-width: 70ch;
    padding-block-end: var(--space-6);
  }

  .related__list {
    margin-block-start: var(--space-3);
  }

  .related__chip {
    text-decoration: none;
  }

  .related__type {
    color: var(--color-text-muted);
  }
</style>
