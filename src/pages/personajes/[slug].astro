---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CharacterDetailHeader from '../../components/CharacterDetailHeader.astro';
import { findMentions } from '../../utils/related';

export async function getStaticPaths() {
  const characters = await getCollection('characters');
  return characters.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'characters'>;
}

const { entry } = Astro.props;
const { name, role, firstAppearance, description } = entry.data;
const { Content } = await entry.render();

const base = import.meta.env.BASE_URL;

// "Relacionados": juegos y entradas de lore mencionados por título en la
// descripción de este personaje (ver src/utils/related.ts).
const [games, loreEntries] = await Promise.all([getCollection('games'), getCollection('lore')]);

const related = findMentions(description, [
  ...games.map((g) => ({
    label: g.data.title,
    type: 'Juego',
    href: `${base}juegos/${g.slug}/`,
  })),
  ...loreEntries.map((l) => ({
    label: l.data.title,
    type: 'Lore',
    href: `${base}lore/${l.slug}/`,
  })),
]);
---

<BaseLayout title={`${name} - Enciclopedia de Donkey Kong`} description={description}>
  <article>
    <CharacterDetailHeader name={name} role={role} firstAppearance={firstAppearance} />

    <div class="character-detail-body">
      <Content />
    </div>

    {related.length > 0 && (
      <section class="related">
        <h2>Relacionados</h2>
        <ul class="chip-list related__list" role="list">
          {related.map((item) => (
            <li>
              <a class="chip related__chip" href={item.href}>
                <span class="related__type">{item.type}:</span> {item.label}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </article>
</BaseLayout>

<style>
  .character-detail-body {
    padding-block: var(--space-6);
    max-width: 70ch;
  }

  .character-detail-body :global(p) {
    margin-block-end: var(--space-4);
  }

  .related {
    max-width: 70ch;
    padding-block-end: var(--space-6);
  }

  .related__list {
    margin-block-start: var(--space-3);
  }

  .related__chip {
    text-decoration: none;
  }

  .related__type {
    color: var(--color-text-muted);
  }
</style>
