---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CharacterCard from '../../components/CharacterCard.astro';

const base = import.meta.env.BASE_URL;

const characters = (await getCollection('characters')).sort((a, b) =>
  a.data.name.localeCompare(b.data.name)
);
---

<BaseLayout
  title="Personajes - Enciclopedia de Donkey Kong"
  description="Listado de personajes del universo Donkey Kong."
>
  <h1>Personajes</h1>
  <p>Todos los personajes del universo Donkey Kong, ordenados alfabéticamente.</p>

  <ul class="card-grid" role="list">
    {characters.map((character) => (
      <li>
        <CharacterCard
          name={character.data.name}
          role={character.data.role}
          description={character.data.description}
          href={`${base}personajes/${character.slug}/`}
        />
      </li>
    ))}
  </ul>
</BaseLayout>
