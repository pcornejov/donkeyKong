---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Página no encontrada"
  description="La página que buscas no existe en la Enciclopedia de Donkey Kong."
>
  <section class="not-found">
    <p class="not-found__eyebrow">Error 404</p>
    <h1>¡Vaya! Este barril se perdió en el camino</h1>
    <p>
      No encontramos la página que buscas. Puede que el enlace esté roto o
      que la entrada se haya movido de sitio.
    </p>

    <div class="not-found__actions">
      <a class="btn" href={base}>Volver al inicio</a>
      <a class="btn" href={`${base}buscar/`}>Buscar en la enciclopedia</a>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-4);
    padding-block: var(--space-7);
    max-width: 60ch;
  }

  .not-found__eyebrow {
    font-family: var(--font-heading);
    font-size: var(--font-size-xs);
    color: var(--color-secondary);
    text-transform: uppercase;
  }

  .not-found__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-block-start: var(--space-2);
  }
</style>
